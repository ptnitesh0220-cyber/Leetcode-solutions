class Solution {
    public int search(int[] nums, int target) {
        int rt=nums.length-1,lt=0;
        while(lt+1<rt){
            int mid=(lt+rt)/2;
            if(nums[mid]<=target) lt=mid;
            else rt=mid;
        }
        return nums[lt]==target?lt:nums[rt]==target?rt:-1;
    }
}
