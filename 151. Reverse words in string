char* reverseWords(char* s) {
    
    int len = strlen(s);
    char *result = malloc(len + 1);
    int pos = 0;

    int end = len - 1;

    while (end >= 0) {
        while (end >= 0 && s[end] == ' ')
            end--;

        if (end < 0)
            break;

        int start = end;
        while (start >= 0 && s[start] != ' ')
            start--;

        for (int i = start + 1; i <= end; i++)
            result[pos++] = s[i];

        result[pos++] = ' ';
        end = start - 1;
    }

    if (pos > 0)
        pos--;  

    result[pos] = '\0';
    return result;
}
