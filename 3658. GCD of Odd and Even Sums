int gcdOfOddEvenSums(int n) {
    int even=0,odd=0;
    int a=1;
    for(int i=0;i<n+n;i++){
        if(a%2==1)
        odd+=a;
        else
        even+=a;
        a++;
    }
    int max=0,c;
    for(int i=1;i<=odd;i++){
            if(even%i==0 && odd%i==0)
            c=i;
            if(c>max)max=c;
        }
        return max;
}
